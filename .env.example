# İsteğe bağlı: çok kullanıcılı bulut depo (Supabase). Boş bırakılırsa uygulama yalnızca yerel dosya + localStorage kullanır.
# https://supabase.com/dashboard — Project Settings → API
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ... veya yeni format: sb_publishable_...

# Kayıt doğrulama e-postası (Resend ücretsiz plan). Bu dosyayı .env olarak kopyalayın; Git'e eklemeyin.
# https://resend.com/api-keys
# VITE_RESEND_API_KEY=re_xxxxxxxx
# VITE_RESEND_FROM=LabStock <onboarding@resend.dev>
